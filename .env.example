# =========================================================================
# MedGuardian — Production Environment Variable Configuration Blueprint
# =========================================================================
# Copy this file to '.env' and secure values before building/deploying.

# 1. Server Environment Configs
APP_ENV=production
DEBUG=False
SECRET_KEY="generate-a-strong-secret-key-for-cookies"
JWT_SECRET_KEY="generate-a-strong-secret-key-for-jwts"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480 # 8-hour shift compliance
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
MIGRATION_CHECK_MODE=warn
AUTO_SEED_DEMO_ON_STARTUP=false
AUTO_SEED_NABH_ON_STARTUP=false
# Keep false unless written source rights and an approved 639-record release
# package have completed the Phase 1.5 publication process.
NABH_FULL_TEXT_PERMISSION_CONFIRMED=false

# 2. Database Integration
# SQLite fallback default: sqlite:///./medguardian.db
# Managed Postgres (Supabase, AWS RDS, GCP CloudSQL) syntax:
DATABASE_URL=postgresql://db_user:db_password@db_host:5432/db_name

# Bootstrap-only credentials. Store them in the deployment secret manager and
# rotate/remove them after the controlled initial bootstrap.
MEDGUARDIAN_SEED_SUPER_ADMIN_PASSWORD=
MEDGUARDIAN_SEED_HOSPITAL_ADMIN_PASSWORD=
MEDGUARDIAN_SEED_DOCTOR_PASSWORD=
MEDGUARDIAN_SEED_NURSE_PASSWORD=
MEDGUARDIAN_SEED_COMPLIANCE_PASSWORD=
MEDGUARDIAN_SEED_ACCOUNTANT_PASSWORD=

# 3. CORS & Ingress Boundaries
# Strictly lock these down to your secure domains in production
BACKEND_CORS_ORIGINS=["https://your-medguardian-app.com", "https://api.your-medguardian-app.com"]

# 4. Hospital Corporate Identity (Configures Reports & Templates)
HOSPITAL_NAME="Mission Hospital"
HOSPITAL_FCRA_NUMBER="FCRA-REG-9827491"
HOSPITAL_NABH_ID="NABH-ACC-2025-0091"
HOSPITAL_STATE="Kerala"
HOSPITAL_DISTRICT="Ernakulam"
